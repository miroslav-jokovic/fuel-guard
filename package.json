{
  "name": "fuelguard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "gen": "pnpm gen:rules",
    "gen:rules": "node scripts/gen-rule-catalog.mjs",
    "lint": "eslint .",
    "lint:filesize": "node scripts/check-file-size.mjs",
    "lint:boundaries": "node scripts/check-feature-boundaries.mjs",
    "lint:codegen": "node scripts/gen-rule-catalog.mjs && git diff --exit-code -- 'packages/**/*.generated.ts'",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
