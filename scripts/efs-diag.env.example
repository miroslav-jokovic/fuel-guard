# Copy this file to  scripts/efs-diag.env  and paste your REAL values from Railway → Variables.
# scripts/efs-diag.env is gitignored, so your secret is never committed.
# Keep the single quotes; put your value between them.
EFS_GRAPH_TENANT_ID='paste-real-tenant-guid-here'
EFS_GRAPH_CLIENT_ID='paste-real-client-guid-here'
EFS_GRAPH_CLIENT_SECRET='paste-real-secret-value-here'
EFS_GRAPH_MAILBOX='reports@yourcompany.com'
EFS_GRAPH_FOLDER='FuelGuard EFS'
