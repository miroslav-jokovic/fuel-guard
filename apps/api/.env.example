NODE_ENV=development
PORT=8080
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# In production set these to the Railway app domain (the URL users visit in their browser and
# click in invite emails). This is NOT the email sender domain — see MAIL_FROM below.
# Production: https://fleetguardweb-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173
WEB_APP_URL=http://localhost:5173
SAMSARA_API_TOKEN=samsara_api_your-token-here
SAMSARA_API_URL=https://api.samsara.com
# Driver-performance score refresh cadence (current week), hours. Default 6.
SAMSARA_DRIVER_SCORE_SYNC_HOURS=6

# ── Email delivery (Resend) ────────────────────────────────────────────────────
# 1. Create an account at https://resend.com and get a free API key.
# 2. Set RESEND_API_KEY below — MAIL_PROVIDER is auto-detected from the key.
# 3. MAIL_FROM uses Resend's shared sender (onboarding@resend.dev) by default.
#    No DNS verification required — just the API key is enough.
#
# When you have DNS access to silvicominc.com, verify it in resend.com/domains
# and switch MAIL_FROM to: FuelGuard <miki@silvicominc.com>
MAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=FuelGuard <onboarding@resend.dev>

# ── HERE Routing API ──────────────────────────────────────────────────────────
# Used for truck-route geometry fetching + caching (route_geometries table).
# Generate at: https://platform.here.com/portal/
HERE_API_KEY=your-here-api-key-here

# Run background schedulers in this API process (default true). Set to false on the API service
# when a dedicated single-replica worker service runs them. See docs/WORKER-DEPLOYMENT.md.
RUN_SCHEDULERS_IN_PROCESS=true
