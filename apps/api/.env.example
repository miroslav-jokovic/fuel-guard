NODE_ENV=development
PORT=8080
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# In production set these to the Railway app domain (the URL users visit in their browser and
# click in invite emails). This is NOT the email sender domain — see MAIL_FROM below.
# Production: https://fleetguardweb-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173
WEB_APP_URL=http://localhost:5173
SAMSARA_API_TOKEN=samsara_api_your-token-here
SAMSARA_API_URL=https://api.samsara.com

# ── Email delivery (Resend) ────────────────────────────────────────────────────
# 1. Create an account at https://resend.com and get an API key.
# 2. Add & verify your sending domain at https://resend.com/domains
#    (add the 3 DNS records Resend shows you — SPF + DKIM + DMARC).
#    Domain to verify: silvicominc.com
# 3. Set RESEND_API_KEY below — MAIL_PROVIDER is auto-detected from the key.
# 4. MAIL_FROM must use the verified domain; the display name is optional.
#
# During initial testing you can use Resend's shared test sender:
#   MAIL_FROM=FuelGuard <onboarding@resend.dev>
# (this only delivers to your own Resend-verified address, not arbitrary recipients)
MAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=FuelGuard <miki@silvicominc.com>
