# FuelGuard McLeod sync agent — configuration.
# Copy this file to `.env` (or set these as real environment variables) and fill in the values.

# ── FuelGuard (required) ────────────────────────────────────────────────────────────────────────────
# Your FuelGuard base URL (no trailing slash).
FUELGUARD_INGEST_URL=https://your-fuelguard-url.example.com
# The ingest token from FuelGuard → Settings → Integrations → McLeod → "Enable" (shown once). Starts with fgtms_.
FUELGUARD_INGEST_TOKEN=fgtms_paste_the_token_here

# ── Which source to read from ─────────────────────────────────────────────────────────────────────────
# Start with 'mock' to prove the FuelGuard connection works, then switch to 'mcleod'.
SOURCE=mock

# How far back to pull on the FIRST run (after that the agent remembers where it left off, in state.json).
LOOKBACK_DAYS=35

# 0 = run once and exit (good with Windows Task Scheduler / cron). >0 = stay running and sync every N minutes.
INTERVAL_MINUTES=0

# ── McLeod LoadMaster (only needed when SOURCE=mcleod) ────────────────────────────────────────────────
MCLEOD_WS_URL=https://your-loadmaster-host/ws
MCLEOD_COMPANY=TMS
MCLEOD_WS_TOKEN=the_web_service_token_mcleod_issues
